FROM node:22-alpine AS base
WORKDIR /app
RUN corepack enable

FROM base AS deps
COPY . .
RUN if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile; else pnpm install; fi

FROM deps AS build
RUN pnpm build

FROM node:22-alpine AS runtime
WORKDIR /app

ARG DB_HOST
ARG DB_PORT=5432
ARG DB_DATABASE
ARG DB_USERNAME
ARG DB_PASSWORD
ARG DB_SSL=false
ARG REDIS_HOST
ARG REDIS_PORT=6379
ARG REDIS_PASSWORD
ARG REDIS_DB=0
ARG PORT=4000
ARG JWT_ACCESS_SECRET
ARG JWT_REFRESH_SECRET
ARG JWT_ACCESS_TTL=15m
ARG JWT_REFRESH_TTL=7d
ARG MELI_CLIENT_ID
ARG MELI_CLIENT_SECRET
ARG MELI_REDIRECT_URI
ARG MELI_API_BASE_URL=https://api.mercadolibre.com
ARG MELI_AUTH_BASE_URL=https://auth.mercadolibre.com
ARG WEB_APP_URL
ARG NEXT_PUBLIC_APP_URL
ARG APP_URL
ARG FRONTEND_URL
ARG NEXT_PUBLIC_API_URL
ARG OPENAI_API_KEY

ENV NODE_ENV=production
ENV DB_HOST=$DB_HOST
ENV DB_PORT=$DB_PORT
ENV DB_DATABASE=$DB_DATABASE
ENV DB_USERNAME=$DB_USERNAME
ENV DB_PASSWORD=$DB_PASSWORD
ENV DB_SSL=$DB_SSL
ENV REDIS_HOST=$REDIS_HOST
ENV REDIS_PORT=$REDIS_PORT
ENV REDIS_PASSWORD=$REDIS_PASSWORD
ENV REDIS_DB=$REDIS_DB
ENV PORT=$PORT
ENV JWT_ACCESS_SECRET=$JWT_ACCESS_SECRET
ENV JWT_REFRESH_SECRET=$JWT_REFRESH_SECRET
ENV JWT_ACCESS_TTL=$JWT_ACCESS_TTL
ENV JWT_REFRESH_TTL=$JWT_REFRESH_TTL
ENV MELI_CLIENT_ID=$MELI_CLIENT_ID
ENV MELI_CLIENT_SECRET=$MELI_CLIENT_SECRET
ENV MELI_REDIRECT_URI=$MELI_REDIRECT_URI
ENV MELI_API_BASE_URL=$MELI_API_BASE_URL
ENV MELI_AUTH_BASE_URL=$MELI_AUTH_BASE_URL
ENV WEB_APP_URL=$WEB_APP_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV APP_URL=$APP_URL
ENV FRONTEND_URL=$FRONTEND_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV OPENAI_API_KEY=$OPENAI_API_KEY
RUN corepack enable

COPY . .
RUN if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile --prod; else pnpm install --prod; fi

COPY --from=build /app/dist ./dist

EXPOSE 4000
CMD ["pnpm", "start"]
